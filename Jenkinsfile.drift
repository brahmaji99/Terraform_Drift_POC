pipeline {
    agent any

    parameters {
        choice(name: 'ENV', choices: ['dev', 'stage', 'prod'], description: 'Environment')
        string(name: 'EMAIL_TO', defaultValue: 'brahma.scm9@gmail.com', description: 'Email recipients')
    }

    environment {
        AWS_DEFAULT_REGION = 'ap-southeast-2'
        BEDROCK_MODEL_ID = 'arn:aws:bedrock:ap-southeast-2:671590543400:inference-profile/apac.anthropic.claude-sonnet-4-20250514-v1:0'
    }

    stages {

        stage('Checkout') {
            steps {
                echo "Checking out code..."
                git branch: 'main', url: 'https://github.com/brahmaji99/Terraform_Drift_POC.git'
            }
        }

        stage('Drift Detection') {
            steps {
                script {
                    echo "Running Terraform drift detection..."

                    def driftStatus = sh(
                        script: "bash scripts/drift_detect.sh ${params.ENV}",
                        returnStatus: true
                    )

                    if (driftStatus == 2) {
                        echo "Drift detected in ${params.ENV}. Running Bedrock risk analysis..."

                        def riskStatus = withEnv([
                            "AWS_DEFAULT_REGION=${env.AWS_DEFAULT_REGION}",
                            "BEDROCK_MODEL_ID=${env.BEDROCK_MODEL_ID}"
                        ]) {
                            sh(
                                script: "python3 scripts/analyze_risk.py reports/drift/${params.ENV}.json",
                                returnStatus: true
                            )
                        }

                        echo "Risk analysis exit code: ${riskStatus}"

                        if (riskStatus >= 1) {
                            echo "Sending notification..."
                            sh "bash scripts/notify.sh ${params.ENV}"
                        }

                        if (riskStatus == 2) {
                            error "HIGH risk detected for ${params.ENV}. Pipeline stopped."
                        }

                    } else if (driftStatus == 0) {
                        echo "No drift detected in ${params.ENV}."
                    } else {
                        error "Drift detection failed with status ${driftStatus}"
                    }
                }
            }
        }
    }

    post {
        always {
            script {
                def envName = params.ENV ?: "dev"
                def reportFile = "reports/risk/${envName}.json"

                echo "Reading report from: ${reportFile}"

                def risk = "UNKNOWN"
                def reason = "N/A"
                def impact = "N/A"
                def recommendation = "N/A"

                if (fileExists(reportFile)) {
                    def report = readJSON file: reportFile

                    risk = report.risk ?: "UNKNOWN"
                    reason = report.reason ?: "N/A"
                    impact = report.impact ?: "N/A"
                    recommendation = report.recommendation ?: "N/A"
                } else {
                    echo "Report file NOT found!"
                }

                // 🎨 Color + Badge
                def color = "#28a745"   // green default
                def badge = "✅"

                if (risk == "HIGH") {
                    color = "#dc3545"   // red
                    badge = "🔥"
                } else if (risk == "MEDIUM") {
                    color = "#ffc107"   // yellow
                    badge = "⚠️"
                }

                // 📧 HTML Email Body
                def emailBody = """
                <html>
                <body style="font-family: Arial, sans-serif;">

                    <h2 style="color:${color};">
                        Terraform Drift Analysis - ${envName} ${badge}
                    </h2>

                    <table style="border-collapse: collapse; width: 100%;">

                        <tr>
                            <td style="border:1px solid #ddd; padding:8px;"><b>Environment</b></td>
                            <td style="border:1px solid #ddd; padding:8px;">${envName}</td>
                        </tr>

                        <tr>
                            <td style="border:1px solid #ddd; padding:8px;"><b>Risk Level</b></td>
                            <td style="border:1px solid #ddd; padding:8px; color:${color}; font-weight:bold;">
                                ${risk} ${badge}
                            </td>
                        </tr>

                        <tr>
                            <td style="border:1px solid #ddd; padding:8px;"><b>Reason</b></td>
                            <td style="border:1px solid #ddd; padding:8px;">${reason}</td>
                        </tr>

                        <tr>
                            <td style="border:1px solid #ddd; padding:8px;"><b>Impact</b></td>
                            <td style="border:1px solid #ddd; padding:8px;">${impact}</td>
                        </tr>

                        <tr>
                            <td style="border:1px solid #ddd; padding:8px;"><b>Recommendation</b></td>
                            <td style="border:1px solid #ddd; padding:8px;">${recommendation}</td>
                        </tr>

                    </table>

                    <br/>
                    <p style="font-size:12px; color:gray;">
                        This is an automated AI-based Terraform drift risk analysis report.
                    </p>

                </body>
                </html>
                """

                // 📎 Send Email with Attachment
                emailext(
                    subject: "🚀 Terraform Drift Report - ${envName} - ${risk}",
                    body: emailBody,
                    to: "your-email@gmail.com",
                    mimeType: 'text/html',
                    attachmentsPattern: reportFile   // ✅ attach JSON
                )
            }
        }
    }
}