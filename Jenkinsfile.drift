pipeline {
    agent any

    // Uncomment if you want scheduled runs
    // triggers {
    //     cron('H/15 * * * *') // runs every 15 minutes
    // }

    parameters {
        choice(name: 'ENV', choices: ['dev', 'stage', 'prod'], description: 'Environment')
    }

    environment {
        AWS_DEFAULT_REGION = 'ap-southeast-2'  // must match EC2/Bedrock region
        BEDROCK_MODEL_ID = 'arn:aws:bedrock:ap-southeast-2:671590543400:inference-profile/apac.anthropic.claude-sonnet-4-20250514-v1:0'
    }

    stages {

        stage('Checkout') {
            steps {
                echo "Checking out code..."
                git branch: 'main', url: 'https://github.com/brahmaji99/Terraform_Drift_POC.git'
            }
        }

        stage('Drift Detection') {
            steps {
                script {
                    echo "Running Terraform drift detection..."
                    // Run drift detection script; returns 2 if drift, 0 if no drift
                    def driftStatus = sh(
                        script: "bash scripts/drift_detect.sh ${params.ENV}",
                        returnStatus: true
                    )

                    if (driftStatus == 2) {
                        echo "Drift detected in ${params.ENV}. Running Bedrock risk analysis..."

                        // Run Python risk analysis with AWS Bedrock
                        def riskStatus = withEnv([
                            "AWS_DEFAULT_REGION=${env.AWS_DEFAULT_REGION}",
                            "BEDROCK_MODEL_ID=${env.BEDROCK_MODEL_ID}"
                        ]) {
                            sh(
                                script: "python3 scripts/analyze_risk.py reports/drift/${params.ENV}.json",
                                returnStatus: true
                            )
                        }

                        echo "Risk analysis exit code: ${riskStatus}"

                        // Send notifications for MEDIUM or HIGH risk
                        if (riskStatus >= 1) {
                            echo "Sending notification for ${params.ENV} environment..."
                            sh "bash scripts/notify.sh ${params.ENV}"
                        }

                        // Stop pipeline if HIGH risk detected
                        if (riskStatus == 2) {
                            error "HIGH risk detected for ${params.ENV}. Pipeline stopped."
                        }

                    } else if (driftStatus == 0) {
                        echo "No drift detected in ${params.ENV}."
                    } else {
                        error "Drift detection script failed with status ${driftStatus}"
                    }
                }
            }
        }
    }

    post {
        success {
            emailext(
                subject: "✅ Drift Pipeline Success - ${params.ENV}",
                body: "No critical drift detected in ${params.ENV}.",
                to: "brahma.scm9@gmail.com"
            )
        }

        failure {
            emailext(
                subject: "🚨 Drift Pipeline FAILED - ${params.ENV}",
                body: "High risk drift detected or pipeline failed.",
                to: "brahma.scm9@gmail.com"
            )
        }
    }
}
